@model IEnumerable<TechMovePOE.API.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<h1>Contracts</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Create New Contract
    </a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement File</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
@foreach (var item in Model)
{
        <tr>

            <td>
                @item.ClientId
            </td>

            <td>
                @item.StartDate.ToShortDateString()
            </td>

            <td>
                @item.EndDate.ToShortDateString()
            </td>

            <td>
                @item.Status
            </td>

            <td>
                @item.ServiceLevel
            </td>

            <td>
                @if (!string.IsNullOrEmpty(item.AgreementFilePath))
                {
                    <a href="@item.AgreementFilePath"
                       target="_blank"
                       class="btn btn-sm btn-primary">
                        Download PDF
                    </a>
                }
                else
                {
                    <span>No File</span>
                }
            </td>

            <td>
                <a asp-action="Edit" asp-route-id="@item.ContractId">
                    Edit
                </a>
                |
                <a asp-action="Details" asp-route-id="@item.ContractId">
                    Details
                </a>
                |
                <a asp-action="Delete" asp-route-id="@item.ContractId">
                    Delete
                </a>
            </td>

        </tr>
}
    </tbody>
</table> 